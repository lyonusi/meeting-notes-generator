{
  "name": "obsidian-meeting-notes-generator",
  "version": "0.1.0",
  "description": "Obsidian plugin: record, transcribe (local Whisper WASM), and generate meeting notes with AWS Bedrock.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "typecheck": "tsc -noEmit -skipLibCheck"
  },
  "keywords": ["obsidian", "plugin", "meeting", "transcription", "whisper", "bedrock"],
  "author": "lyonusi",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.0",
    "obsidian": "^1.4.11",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.540.0",
    "@aws-sdk/credential-providers": "^3.540.0",
    "@xenova/transformers": "^2.17.1"
  }
}
